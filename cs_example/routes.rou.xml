<routes>

    <vType  id="EV" minGap="2.5" maxSpeed="41.66" emissionClass="Energy/unknown" color="green" accel="1" decel="1" sigma="0">
        <param key="has.battery.device" value="true"/>
        <param key="device.battery.capacity" value="64000"/>
        <param key="device.battery.chargeLevel" value="4000"/> 
        <param key="allowedPowerIntake" value="120000"/>
        
        <param key="has.stationfinder.device" value="true"/>
        <param key="device.stationfinder.checkEnergyForRoute" value="false"/>
        <param key="device.stationfinder.waitForCharge" value="180"/> <!-- reroute if cs is being used, experimental value of 10 works fine -->
        
        <param key="device.battery.stoppingTreshold" value="0.1"/>
        <param key="device.stationfinder.replacePlannedStop" value="0"/>
        <param key="device.stationfinder.repeat" value="10"/> 
        <param key="device.stationfinder.charging.waitingTime.weight" value="5"/> <!-- >1 so waiting is penalized and the vehicle reroutes -->
        <param key="device.stationfinder.radius" value="300000"/>  <!-- needed to increase search radius in seconds -->
        
        <param key="airDragCoefficient" value="0.35"/>
        <param key="constantPowerIntake" value="160"/>
        <param key="frontSurfaceArea" value="3"/>
        <param key="rotatingMass" value="0.01"/>      
        <param key="propulsionEfficiency" value="0.9"/>
        <param key="radialDragCoefficient" value="0.5"/>
        <param key="recuperationEfficiency" value="0.9"/>
        <param key="rollDragCoefficient" value="0.01"/>        
        <param key="mass" value="1615"/>        
    </vType>

     <flow id="ev_flow_0"
          type="EV"
          from="e1"
          to="e3"
          begin="0"
          end="3600"
          number="150"/>
          
</routes>

